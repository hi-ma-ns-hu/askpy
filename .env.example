# ── Environment ──────────────────────────────────────────────────────────────
APP_ENV=DEVELOPMENT
LOG_LEVEL=INFO
DEBUG=True

# ── LLM (OpenAI) — REQUIRED ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Cache (Redis) — OPTIONAL (app runs cache-less if unset) ──────────────────
REDIS_URL=redis://localhost:6379/0

# ── Vector store (Qdrant Cloud — free tier) ──────────────────────────────────
# Create a free cluster at https://cloud.qdrant.io
QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=

# ── Reranker (Cohere) ────────────────────────────────────────────────────────
# Free trial key at https://dashboard.cohere.com
COHERE_API_KEY=

# ── Kaggle (only needed for ingestion) ──────────────────────────────────────
KAGGLE_API_TOKEN=